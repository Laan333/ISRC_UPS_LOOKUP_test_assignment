## Example environment file for local/dev runs.
##
## Copy to ".env" and adjust as needed. Docker Compose reads this file for variable substitution.

# --- nginx (docker compose) ---
# Published host port for nginx HTTP (container still listens on 80 inside). Use 8080 if 80 is busy.
# NGINX_HTTP_PORT=8080
# Host port for HTTPS (only applied when you start with: -f docker-compose.https.yml). Default 443.
# NGINX_HTTPS_PORT=443

# HTTPS termination in nginx (optional). Place PEM files in ./certs — see certs/README.md
# NGINX_SSL_ENABLED=false
# NGINX_SSL_CERT_DIR=./certs
# NGINX_SSL_CERT=/etc/nginx/ssl/fullchain.pem
# NGINX_SSL_KEY=/etc/nginx/ssl/privkey.pem

# --- app (passed into the api container) ---
# Public base URL for OpenAPI "Try it out" (must match how users open the UI: same scheme/host/port as nginx).
# Use http://... when NGINX_SSL_ENABLED=false, https://... when TLS is enabled.
# MUST include the port if nginx is not on 80, e.g. http://95.81.98.168:7000
# Examples: http://localhost:8080  |  https://api.example.com
OPENAPI_SERVER_URL=https://pulsetg.ru/
# Optional: GET /ready probes this URL; use your public /health if you want to verify the edge URL.
READY_CHECK_URL=https://pulsetg.ru/health

# Optional: outgoing User-Agent for provider requests
USER_AGENT=ISRC_UPS_Lookup/1.0 (local)

# Logging (api container; host path ./logs via docker compose volume)
# LOG_LEVEL=INFO
# LOG_FILE_PATH=logs/app.log
# Leave empty for stdout-only: LOG_FILE_PATH=
# LOG_MAX_BYTES=5000000
# LOG_BACKUP_COUNT=5

# Browser CORS for /docs / Scalar ("Try it out"). Default * ; empty string disables.
# CORS_ALLOW_ORIGINS=*

# Providers toggles
PROVIDER_MUSICBRAINZ_ENABLED=true
PROVIDER_DEEZER_ENABLED=true
PROVIDER_DISCOGS_ENABLED=true
PROVIDER_WIKIDATA_ENABLED=true
PROVIDER_OPEN_LIBRARY_ENABLED=true

# Spotify Web API (optional). Server-side Client Credentials only — never expose the secret to browsers.
# Create an app: https://developer.spotify.com/dashboard
# PROVIDER_SPOTIFY_ENABLED=false
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_ACCOUNTS_URL=https://accounts.spotify.com
# SPOTIFY_API_BASE_URL=https://api.spotify.com
