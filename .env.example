## Example environment file for local/dev runs.
##
## Copy to ".env" and adjust as needed. Docker Compose reads this file for variable substitution
## and passes it into the `api` container as `env_file` (see docker-compose.yml).

# --- nginx (docker compose) ---
# Published host port for nginx HTTP (container still listens on 80 inside). Use 8080 if 80 is busy.
# NGINX_HTTP_PORT=8080
# Host port for HTTPS (only applied when you start with: -f docker-compose.https.yml). Default 443.
# NGINX_HTTPS_PORT=443

# HTTPS termination in nginx (optional). Place PEM files in ./certs — see certs/README.md
# NGINX_SSL_ENABLED=false
# NGINX_SSL_CERT_DIR=./certs
# NGINX_SSL_CERT=/etc/nginx/ssl/fullchain.pem
# NGINX_SSL_KEY=/etc/nginx/ssl/privkey.pem

# --- app (passed into the api container) ---
# Public base URL for OpenAPI "Try it out" (must match how users open the UI: same scheme/host/port as nginx).
# Use http://... when NGINX_SSL_ENABLED=false, https://... when TLS is enabled.
# MUST include the port if nginx is not on 80, e.g. http://203.0.113.10:7000
# Examples: http://localhost  |  http://localhost:8080  |  https://api.example.com
OPENAPI_SERVER_URL=http://localhost
# Optional: GET /ready probes this URL; use your public /health if you want to verify the edge URL.
# READY_CHECK_URL=http://localhost/health
# If the public URL is unreachable from inside the api container (Docker hairpin), set a fallback
# reachable on the compose network (docker-compose defaults this to http://nginx/health).
# Disable compose default by setting empty: READY_CHECK_FALLBACK_URL=
# READY_CHECK_FALLBACK_URL=http://nginx/health

# Outgoing User-Agent for provider HTTP calls (quote if the value contains spaces).
# Note: in Docker Compose the `api` service sets USER_AGENT in the `environment:` block, which overrides
# this file for that variable — change docker-compose.yml if you need a custom UA in containers.
USER_AGENT="ISRC_UPS_Lookup/1.0 (local)"

# APP_VERSION=0.1.0

# Logging (api container; host path ./logs via docker compose volume)
# LOG_LEVEL=INFO
# LOG_FILE_PATH=logs/app.log
# Leave empty for stdout-only: LOG_FILE_PATH=
# LOG_MAX_BYTES=5000000
# LOG_BACKUP_COUNT=5

# Browser CORS for /docs / Scalar ("Try it out"). Default * ; empty string disables.
# CORS_ALLOW_ORIGINS=*

# HTTP client (defaults match README / app/config.py)
# HTTP_TIMEOUT_S=15
# HTTP_GET_MAX_RETRIES=2
# HTTP_GET_RETRY_BACKOFF_S=0.15
# OUTBOUND_MAX_CONCURRENT=16
# MAX_RESPONSE_BODY_BYTES=2000000
# API_RATE_LIMIT_PER_MINUTE=120

# Lookup cache (in-process)
# LOOKUP_CACHE_ENABLED=true
# LOOKUP_CACHE_TTL_S=300
# LOOKUP_CACHE_MAX_ENTRIES=512

# Providers toggles
PROVIDER_MUSICBRAINZ_ENABLED=true
PROVIDER_DEEZER_ENABLED=true
PROVIDER_DISCOGS_ENABLED=true
PROVIDER_WIKIDATA_ENABLED=true
PROVIDER_OPEN_LIBRARY_ENABLED=true

# Rarely change: Open Library search endpoint
# OPEN_LIBRARY_SEARCH_URL=https://openlibrary.org/search.json

# Discogs — https://www.discogs.com/developers/#page:authentication (Discogs Auth)
# «Логин потребителя» / «Пароль потребителя» in the developer app = Consumer Key + Consumer Secret
# (application credentials, NOT your discogs.com account password). Header: Authorization: Discogs key=…, secret=…
# Env aliases (see app/config.py): DISCOGS_CONSUMER_KEY | DISCOGS_CONSUMER_LOGIN | DISCOGS_LOGIN
# DISCOGS_CONSUMER_SECRET | DISCOGS_CONSUMER_PASSWORD | DISCOGS_PASSWORD
# DISCOGS_CONSUMER_KEY=
# DISCOGS_CONSUMER_SECRET=
# Alternative: personal token (if set, key/secret pair is not used).
# DISCOGS_PERSONAL_ACCESS_TOKEN=
